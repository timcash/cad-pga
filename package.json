{
  "name": "cad-pga",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "legion:dev": "concurrently \"vite\" \"tsx server/ws-lab/index.ts\"",
    "legion:server": "tsx server/ws-lab/index.ts",
    "legion:daemon:start": "tsx server/ws-lab/manage.ts start",
    "legion:daemon:stop": "tsx server/ws-lab/manage.ts stop",
    "legion:daemon:status": "tsx server/ws-lab/manage.ts status",
    "legion:tunnel:provision": "tsx server/ws-lab/manage.ts provision",
    "legion:tunnel:start": "tsx server/ws-lab/manage.ts tunnel",
    "codex:dev": "concurrently \"vite\" \"tsx server/index.ts\"",
    "codex:bridge": "tsx server/index.ts",
    "codex:preview": "npm run build && tsx server/index.ts",
    "codex:daemon:start": "tsx server/daemon/manage.ts start",
    "codex:daemon:stop": "tsx server/daemon/manage.ts stop",
    "codex:daemon:status": "tsx server/daemon/manage.ts status",
    "codex:tunnel": "tsx server/daemon/manage.ts tunnel",
    "build": "vite build",
    "build:pages": "node scripts/build-pages.mjs",
    "preview": "vite preview",
    "capture:screenshots": "tsx scripts/generate-screenshots.ts",
    "test:ui": "npm run build && npm run capture:screenshots",
    "test:ui:headed": "npm run build && tsx scripts/generate-screenshots.ts --headed"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "puppeteer": "^24.25.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "mathjax": "^4.1.1",
    "node-pty": "^1.0.0",
    "prismjs": "^1.30.0",
    "ws": "^8.18.3"
  }
}
